// Stdlib test: Amalgame.Database.PostgreSQL — libpq binding.
// Self-contained schema namespace (`amctest_*` prefix) so a
// shared dev server isn't polluted. Tests CREATE / INSERT /
// SELECT / DROP.
//
// Connection string comes from the environment-set PG* variables
// libpq reads automatically (PGHOST, PGPORT, PGUSER, PGPASSWORD,
// PGDATABASE), so the .am file itself doesn't carry credentials.
// The test runner exports those before invoking us.

namespace Tests

import Amalgame.Database.PostgreSQL

public class Program {
    public static void Main(string[] args) {

        // Empty conn string => libpq pulls every keyword from the
        // PG* env vars. That's the standard pattern for tests +
        // small scripts.
        let db = PostgreSQL.Open("")
        if (PostgreSQL.IsOpen(db)) {
            Console.WriteLine("[PASS] open via PG* env")
        } else {
            Console.WriteLine("[FAIL] open: " + PostgreSQL.LastError(db))
            return
        }

        // ── ServerVersion ────────────────────────────────────
        let ver: string = PostgreSQL.ServerVersion(db)
        if (String_Length(ver) > 0) {
            Console.WriteLine("[PASS] ServerVersion: " + ver)
        } else {
            Console.WriteLine("[FAIL] ServerVersion empty")
        }

        // ── DDL: clean slate + table ──────────────────────────
        PostgreSQL.Exec(db, "DROP TABLE IF EXISTS amctest_notes")
        let createOk: bool = PostgreSQL.Exec(db,
            "CREATE TABLE amctest_notes (id SERIAL PRIMARY KEY, body TEXT)")
        if (createOk) {
            Console.WriteLine("[PASS] CREATE TABLE")
        } else {
            Console.WriteLine("[FAIL] CREATE: " + PostgreSQL.LastError(db))
        }

        // ── INSERT (3 rows) ───────────────────────────────────
        PostgreSQL.Exec(db, "INSERT INTO amctest_notes (body) VALUES ('alpha')")
        PostgreSQL.Exec(db, "INSERT INTO amctest_notes (body) VALUES ('beta')")
        PostgreSQL.Exec(db, "INSERT INTO amctest_notes (body) VALUES ('gamma')")
        // Changes() reports the rows affected by the LAST exec.
        let lastChg: int = PostgreSQL.Changes(db)
        if (lastChg == 1) {
            Console.WriteLine("[PASS] INSERT Changes==1")
        } else {
            Console.WriteLine("[FAIL] INSERT Changes=" + String_FromInt(lastChg))
        }

        // ── SELECT — 3 rows × 2 cols ─────────────────────────
        let rows = PostgreSQL.QueryAll(db,
            "SELECT id, body FROM amctest_notes ORDER BY id")
        if (rows.Count() == 3) {
            Console.WriteLine("[PASS] SELECT 3 rows")
        } else {
            Console.WriteLine("[FAIL] SELECT got " + String_FromInt(rows.Count())
                + " rows")
        }

        // ── Verify cell content ──────────────────────────────
        let row0 = rows.Get(0)
        let row1 = rows.Get(1)
        let row2 = rows.Get(2)
        let body0: string = row0.Get(1)
        let body1: string = row1.Get(1)
        let body2: string = row2.Get(1)
        let okBodies: bool = body0 == "alpha"
        let okBodies2: bool = body1 == "beta"
        let okBodies3: bool = body2 == "gamma"
        if (okBodies && okBodies2 && okBodies3) {
            Console.WriteLine("[PASS] SELECT cell content")
        } else {
            Console.WriteLine("[FAIL] cells: '" + body0 + "' / '"
                + body1 + "' / '" + body2 + "'")
        }

        // ── Verify SERIAL id starts at 1 ─────────────────────
        let id0: string = row0.Get(0)
        if (id0 == "1") {
            Console.WriteLine("[PASS] SERIAL id starts at 1")
        } else {
            Console.WriteLine("[FAIL] id0 = '" + id0 + "'")
        }

        // ── UPDATE — Changes returns affected count ──────────
        PostgreSQL.Exec(db,
            "UPDATE amctest_notes SET body = 'updated' WHERE body = 'alpha' OR body = 'beta'")
        let chgUpd: int = PostgreSQL.Changes(db)
        if (chgUpd == 2) {
            Console.WriteLine("[PASS] UPDATE Changes==2")
        } else {
            Console.WriteLine("[FAIL] UPDATE Changes=" + String_FromInt(chgUpd))
        }

        // ── Bad SQL → LastError populated ────────────────────
        let badOk: bool = PostgreSQL.Exec(db, "INVALID SQL HERE")
        if (badOk) {
            Console.WriteLine("[FAIL] invalid sql returned OK")
        } else {
            // Just check the error string is non-empty.
            let err: string = PostgreSQL.LastError(db)
            if (String_Length(err) > 0) {
                Console.WriteLine("[PASS] bad SQL reports error")
            } else {
                Console.WriteLine("[FAIL] bad SQL: no error string")
            }
        }

        // ── Cleanup + close ──────────────────────────────────
        PostgreSQL.Exec(db, "DROP TABLE amctest_notes")
        PostgreSQL.Close(db)
        if (!PostgreSQL.IsOpen(db)) {
            Console.WriteLine("[PASS] Close drops connection")
        } else {
            Console.WriteLine("[FAIL] still open after Close")
        }
    }
}
